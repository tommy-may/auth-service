{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.prettier": "explicit",
    "source.fixAll.eslint": "explicit"
  },

  "files.exclude": {
    "**/node_modules": true,
    ".eslintcache": true
  },

  "cSpell.words": ["treeify", "uuidv", "vars"]
}
